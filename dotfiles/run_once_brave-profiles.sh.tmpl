#!/usr/bin/env bash
# brave-profiles — seeds Brave Browser with three named profiles.
# Idempotent: skips profiles and Local State that already exist.
# profile-version: v1.0.0

set -euo pipefail

BRAVE_DATA="$HOME/Library/Application Support/BraveSoftware/Brave-Browser"
BRAVE_APP="/Applications/Brave Browser.app"

if [[ ! -d "$BRAVE_APP" ]]; then
  echo "brave-profiles: Brave Browser not installed, skipping"
  exit 0
fi

mkdir -p "$BRAVE_DATA"
echo "brave-profiles: seeding profiles..."

# --- Profile directories + minimal Preferences ---
# Order: Default=Personal, Profile 1=Adobe, Profile 2=UV Cyber
profile_dirs=("Default" "Profile 1" "Profile 2")
profile_names=("Personal" "Adobe" "UV Cyber")

for i in 0 1 2; do
  dir="${profile_dirs[$i]}"
  name="${profile_names[$i]}"
  prefs="$BRAVE_DATA/$dir/Preferences"

  mkdir -p "$BRAVE_DATA/$dir"

  if [[ ! -f "$prefs" ]]; then
    printf '{"profile":{"name":"%s","is_using_default_name":false}}\n' "$name" > "$prefs"
    echo "  ✓ created: $name ($dir)"
  else
    echo "  – exists:  $name ($dir)"
  fi
done

# --- Local State — profile registry (only write if Brave has never launched) ---
LOCAL_STATE="$BRAVE_DATA/Local State"
if [[ ! -f "$LOCAL_STATE" ]]; then
  cat > "$LOCAL_STATE" <<'LOCALSTATE'
{
  "profile": {
    "info_cache": {
      "Default": {
        "avatar_icon": "chrome://theme/IDR_PROFILE_AVATAR_0",
        "is_using_default_name": false,
        "name": "Personal"
      },
      "Profile 1": {
        "avatar_icon": "chrome://theme/IDR_PROFILE_AVATAR_1",
        "is_using_default_name": false,
        "name": "Adobe"
      },
      "Profile 2": {
        "avatar_icon": "chrome://theme/IDR_PROFILE_AVATAR_2",
        "is_using_default_name": false,
        "name": "UV Cyber"
      }
    },
    "last_used": "Default"
  }
}
LOCALSTATE
  echo "  ✓ created Local State"
else
  echo "  – Local State already exists (Brave previously launched)"
fi

echo "brave-profiles: done"
