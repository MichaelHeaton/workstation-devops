# ~/.mcp/env/atlassian.env — Atlassian MCP server credentials
# Copy to atlassian.env and fill in your values, or point servers.json.tmpl
# at an existing env file (e.g. ~/.cursor/.env) that already has these vars.
#
# Get your token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://jira.corp.adobe.com
CONFLUENCE_URL=https://wiki.corp.adobe.com
JIRA_USERNAME=your_ldap@adobe.com
JIRA_PERSONAL_TOKEN=your_token_here
CONFLUENCE_USERNAME=your_ldap@adobe.com
CONFLUENCE_PERSONAL_TOKEN=your_token_here
