{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# apple-notes-defaults — smart quotes/dashes off for pasted code in Notes.
# notes-defaults-version: v1.0.2

set -euo pipefail

NOTES_PLIST="${HOME}/Library/Containers/com.apple.Notes/Data/Library/Preferences/com.apple.Notes.plist"
BUDDY=/usr/libexec/PlistBuddy

set_plist_bool() {
  local key="$1" value="$2"
  if "${BUDDY}" -c "Print :${key}" "${NOTES_PLIST}" &>/dev/null; then
    local current
    current=$("${BUDDY}" -c "Print :${key}" "${NOTES_PLIST}" 2>/dev/null) || return 1
    if [[ "${current}" == "${value}" ]]; then
      return 0
    fi
    "${BUDDY}" -c "Set :${key} ${value}" "${NOTES_PLIST}" 2>/dev/null || return 1
  else
    "${BUDDY}" -c "Add :${key} bool ${value}" "${NOTES_PLIST}" 2>/dev/null || return 1
  fi
  return 0
}

if [[ ! -d "/Applications/Notes.app" ]]; then
  echo "apple-notes-defaults: Notes.app not installed, skipping"
  exit 0
fi

if pgrep -xq Notes 2>/dev/null; then
  echo "apple-notes-defaults: quitting Notes.app so sandboxed preferences can be updated..."
  osascript -e 'tell application "Notes" to quit' || true
  sleep 1
fi

echo "apple-notes-defaults: applying substitution overrides..."

plist_ok=true
if [[ -f "${NOTES_PLIST}" ]]; then
  set_plist_bool NSAutomaticQuoteSubstitutionEnabled false || plist_ok=false
  set_plist_bool NSAutomaticDashSubstitutionEnabled false || plist_ok=false
  if [[ "${plist_ok}" == true ]]; then
    echo "apple-notes-defaults: updated ${NOTES_PLIST}"
  fi
else
  echo "apple-notes-defaults: plist not found (${NOTES_PLIST})"
  plist_ok=false
fi

if [[ "${plist_ok}" != true ]]; then
  echo "apple-notes-defaults: falling back to NSGlobalDomain (system-wide smart quotes/dashes off)"
  defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
  defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
fi

echo "apple-notes-defaults: done (reopen Notes when ready)"
{{ end -}}
