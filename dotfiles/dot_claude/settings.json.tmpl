{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git -C:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(glab issue:*)",
      "Bash(* --help*)",
      "Bash(* --version)",
      "WebSearch",
      "mcp__atlassian__jira_search",
      "mcp__atlassian__jira_get_issue",
      "mcp__atlassian__jira_get_all_projects",
      "mcp__atlassian__jira_get_project_issues",
      "mcp__atlassian__jira_get_project_components",
      "mcp__atlassian__jira_get_project_versions",
      "mcp__atlassian__jira_get_transitions",
      "mcp__atlassian__jira_batch_get_changelogs",
      "mcp__atlassian__confluence_get_page",
      "mcp__atlassian__confluence_search",
      "Skill(issue-get)",
      "Skill(issue-get:*)",
      "Skill(skill-review)",
      "Skill(skill-review:*)",
      "Skill(repo-setup)",
      "Skill(repo-setup:*)",
      "Bash(bash ~/.claude/skills/issue-create/scripts/detect-context.sh)",
      "Bash(bash ~/.claude/skills/session-close/scripts/discover-repos.sh)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/sso/cache/**)",
      "Edit(~/.aws/**)",
      "Read(~/.git-credentials)",
      "Edit(~/.git-credentials)",
      "Read(~/.config/gh/hosts.yml)",
      "Edit(~/.config/gh/hosts.yml)",
      "Read(**/*-service-account.json)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/Library/Keychains/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.cargo/credentials.toml)",
      "Read(~/.composer/auth.json)",
      "Read(~/.gem/credentials)",
      "Read(~/.my.cnf)",
      "Read(~/.pgpass)",
      "Read(~/.config/bw/**)",
      "Read(~/.config/op/**)",
      "Read(~/.config/vault/**)",
      "Read(~/.netrc)",
      "Read(~/.vault-token)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.env.dev)",
      "Read(**/.env.prod)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Edit(**/.env.production)",
      "Edit(**/.env.staging)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.ppk)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/*.ppk)",
      "Edit(~/.bash_profile)",
      "Edit(~/.bashrc)",
      "Edit(~/.profile)",
      "Edit(~/.zprofile)",
      "Edit(~/.zshrc)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/credentials.json)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{ .chezmoi.homeDir }}/.claude/hooks/block-env-read.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if ! command -v jq >/dev/null 2>&1; then echo 'WARN: jq not installed; recursive-rm hook disabled.' >&2; exit 0; fi; input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // .input.command // empty'); if echo \"$cmd\" | grep -qE '^\\s*rm\\s+(-[a-zA-Z]*r[a-zA-Z]*f[a-zA-Z]*|(-[a-zA-Z]*f[a-zA-Z]*\\s+)?-[a-zA-Z]*r[a-zA-Z]*)\\s'; then echo 'BLOCKED: recursive delete detected. Use a scoped rm or trash instead.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "if ! command -v jq >/dev/null 2>&1; then echo 'WARN: jq not installed; main-push hook disabled.' >&2; exit 0; fi; input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // .input.command // empty'); if echo \"$cmd\" | grep -qE 'git\\s+push\\s+\\S+\\s+(main|master)(\\s|$)'; then echo 'BLOCKED: pushing directly to main/master. Use a feature branch and create a PR instead.' >&2; exit 2; fi; if echo \"$cmd\" | grep -qE '^\\s*git\\s+push\\s*$'; then branch=$(git branch --show-current 2>/dev/null); if [ \"$branch\" = main ] || [ \"$branch\" = master ]; then echo 'BLOCKED: pushing directly to main/master. Use a feature branch and create a PR instead.' >&2; exit 2; fi; fi"
          },
          {
            "type": "command",
            "command": "if ! command -v jq >/dev/null 2>&1; then echo 'WARN: jq not installed; pipe-to-shell hook disabled.' >&2; exit 0; fi; input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // .input.command // empty'); if echo \"$cmd\" | grep -qE '(curl|wget)\\s.*\\|\\s*(bash|sh|zsh|dash|ksh|python|perl|ruby|node)'; then echo 'BLOCKED: pipe-to-shell pattern detected. Download the script first, review it, then run it.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "if ! command -v jq >/dev/null 2>&1; then echo 'WARN: jq not installed; find-exec hook disabled.' >&2; exit 0; fi; input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // .input.command // empty'); if echo \"$cmd\" | grep -qE '(^|\\s)find\\s.*-(exec|execdir|ok|okdir|delete|fprint|fprintf|fprint0)(\\s|$)'; then echo 'BLOCKED: find with -exec/-execdir/-delete/-fprint* can run arbitrary commands or modify files. Use a scoped command or request explicit approval.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "theme": "dark",
  "teammateMode": "tmux"
}
